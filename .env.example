# Copy to .dev.vars for local development.
# For production, push with `wrangler secret put <NAME>` or set in the Trigger.dev dashboard.

# ── AI services ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=
ASSEMBLYAI_API_KEY=
FAL_KEY=
PEXELS_API_KEY=

# ── R2 S3-compatible credentials (for the presigner; NOT the binding) ──
R2_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ivoreel

# ── Trigger.dev ────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=tr_...
CF_WORKER_URL=http://localhost:8787

# ── Webhook signing (shared between Worker + Trigger.dev task) ─────────
WEBHOOK_SIGNING_SECRET=change-me-to-32-plus-random-bytes

# ── Auth.js ────────────────────────────────────────────────────────────
AUTH_SECRET=change-me
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Remotion (Trigger.dev task env) ────────────────────────────────────
REMOTION_SERVE_URL=https://<your-bundle-url>
