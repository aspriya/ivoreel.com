{
  "name": "ivoreel",
  "version": "0.1.0",
  "private": true,
  "description": "AI Faceless Reel Composer — generates vertical 1080x1920 Reels from a text script.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply ivoreel-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ivoreel-db --remote",
    "remotion:preview": "remotion studio remotion/index.ts",
    "remotion:bundle": "remotion bundle remotion/index.ts",
    "trigger:dev": "npx trigger.dev@latest dev",
    "trigger:deploy": "npx trigger.dev@latest deploy"
  },
  "dependencies": {
    "@auth/d1-adapter": "^1.7.0",
    "@aws-sdk/client-s3": "^3.650.0",
    "@aws-sdk/s3-request-presigner": "^3.650.0",
    "@fal-ai/client": "^1.2.0",
    "@opennextjs/cloudflare": "^1.0.0",
    "@remotion/bundler": "^4.0.0",
    "@remotion/captions": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@trigger.dev/sdk": "^3.3.0",
    "assemblyai": "^4.7.0",
    "next": "^15.3.0",
    "next-auth": "5.0.0-beta.25",
    "openai": "^4.67.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@trigger.dev/build": "^3.3.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.90.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
